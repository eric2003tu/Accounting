generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String?  @map("first_name")
  lastName     String?  @map("last_name")
  systemRole   String?  @map("system_role")
  phone        String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  businessUsers        BusinessUser[]
  notifications        Notification[]
  ownerApplications    OwnerApplication[]     @relation("Applicant")
  reviewedApplications OwnerApplication[]     @relation("Reviewer")

  @@map("users")
}

model Business {
  id              Int       @id @default(autoincrement())
  name            String
  legalName       String?   @map("legal_name")
  tradeName       String?   @map("trade_name")
  vatNumber       String?   @map("vat_number")
  registrationNo  String?   @map("registration_no")
  currency        String?   @default("RWF")
  timezone        String?
  address         String?
  city            String?
  country         String?
  industry        String?
  status          String?
  subscription    String?
  billingCycle    String?   @map("billing_cycle")
  nextBillingDate DateTime? @map("next_billing_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  businessUsers     BusinessUser[]
  products          Product[]
  categories        Category[]
  contacts          Contact[]
  warehouses        Warehouse[]
  accounts          Account[]
  fiscalYears       FiscalYear[]
  journalEntries    JournalEntry[]
  sales             Sale[]
  purchases         Purchase[]
  receivables       Receivable[]
  payables          Payable[]
  stockMovements    StockMovement[]
  ownerApplications OwnerApplication[]
  notifications     Notification[]

  @@map("businesses")
}

model BusinessUser {
  id         Int    @id @default(autoincrement())
  businessId Int    @map("business_id")
  userId     Int    @map("user_id")
  role       String

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@map("business_users")
}

model Category {
  id          Int      @id @default(autoincrement())
  businessId  Int      @map("business_id")
  name        String
  description String?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products Product[]

  @@map("categories")
}

model Product {
  id            Int      @id @default(autoincrement())
  businessId    Int      @map("business_id")
  categoryId    Int?     @map("category_id")
  name          String
  sku           String?
  unitCost      Decimal? @map("unit_cost")
  unitPrice     Decimal? @map("unit_price")
  stockQuantity Int?     @map("stock_quantity")
  reorderLevel  Int?     @map("reorder_level")
  status        String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  business       Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category       Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  saleItems      SaleItem[]
  purchaseItems  PurchaseItem[]
  stockMovements StockMovement[]

  @@map("products")
}

model Contact {
  id          Int      @id @default(autoincrement())
  businessId  Int      @map("business_id")
  name        String
  email       String?
  phone       String?
  address     String?
  contactType String?  @map("contact_type")

  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sales       Sale[]       @relation("Customer")
  purchases   Purchase[]   @relation("Supplier")
  receivables Receivable[] @relation("ReceivableCustomer")
  payables    Payable[]    @relation("PayableSupplier")

  @@map("contacts")
}

model Warehouse {
  id         Int      @id @default(autoincrement())
  businessId Int      @map("business_id")
  name       String
  location   String?

  business          Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  fromStockMovements StockMovement[] @relation("FromWarehouse")
  toStockMovements   StockMovement[] @relation("ToWarehouse")

  @@map("warehouses")
}

model Account {
  id         Int      @id @default(autoincrement())
  businessId Int      @map("business_id")
  name       String
  code       String?
  type       String?
  balance    Decimal?

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  journalLines JournalLine[]

  @@map("accounts")
}

model FiscalYear {
  id        Int      @id @default(autoincrement())
  businessId Int      @map("business_id")
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isOpen    Boolean  @default(true) @map("is_open")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("fiscal_years")
}

model JournalEntry {
  id          Int      @id @default(autoincrement())
  businessId  Int      @map("business_id")
  reference   String?
  date        DateTime @default(now())
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  lines    JournalLine[]

  @@map("journal_entries")
}

model JournalLine {
  id             Int      @id @default(autoincrement())
  journalEntryId Int      @map("journal_entry_id")
  accountId      Int      @map("account_id")
  amount         Decimal
  type           String
  description    String?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@map("journal_lines")
}

model Sale {
  id            Int       @id @default(autoincrement())
  businessId    Int       @map("business_id")
  reference     String?
  customerId    Int?      @map("customer_id")
  saleDate      DateTime  @map("sale_date")
  total         Decimal?
  paid          Decimal?
  status        String?
  paymentMethod String?   @map("payment_method")
  dueDate       DateTime? @map("due_date")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  business Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Contact?   @relation("Customer", fields: [customerId], references: [id], onDelete: SetNull)
  items    SaleItem[]

  @@map("sales")
}

model SaleItem {
  id        Int      @id @default(autoincrement())
  saleId    Int      @map("sale_id")
  productId Int      @map("product_id")
  qty       Decimal
  unitPrice Decimal? @map("unit_price")
  total     Decimal?

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("sale_items")
}

model Purchase {
  id            Int       @id @default(autoincrement())
  businessId    Int       @map("business_id")
  reference     String?
  supplierId    Int?      @map("supplier_id")
  purchaseDate  DateTime  @map("purchase_date")
  total         Decimal?
  paid          Decimal?
  status        String?
  paymentMethod String?   @map("payment_method")
  dueDate       DateTime? @map("due_date")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier Contact?      @relation("Supplier", fields: [supplierId], references: [id], onDelete: SetNull)
  items    PurchaseItem[]

  @@map("purchases")
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int      @map("purchase_id")
  productId  Int?     @map("product_id")
  qty        Decimal
  unitCost   Decimal? @map("unit_cost")
  total      Decimal?

  purchase Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("purchase_items")
}

model Notification {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  businessId Int?     @map("business_id")
  title      String?
  body       String?
  level      String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  user     User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Receivable {
  id         Int       @id @default(autoincrement())
  businessId Int       @map("business_id")
  customerId Int?      @map("customer_id")
  amount     Decimal?
  dueDate    DateTime? @map("due_date")
  status     String?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Contact? @relation("ReceivableCustomer", fields: [customerId], references: [id], onDelete: SetNull)

  @@map("receivables")
}

model Payable {
  id         Int       @id @default(autoincrement())
  businessId Int       @map("business_id")
  supplierId Int?      @map("supplier_id")
  amount     Decimal?
  dueDate    DateTime? @map("due_date")
  status     String?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier Contact? @relation("PayableSupplier", fields: [supplierId], references: [id], onDelete: SetNull)

  @@map("payables")
}

model StockMovement {
  id              Int      @id @default(autoincrement())
  businessId      Int      @map("business_id")
  productId       Int      @map("product_id")
  qty             Decimal?
  fromWarehouseId Int?     @map("from_warehouse_id")
  toWarehouseId   Int?     @map("to_warehouse_id")
  reason          String?
  createdAt       DateTime @default(now()) @map("created_at")

  business      Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product       Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse? @relation("FromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: SetNull)
  toWarehouse   Warehouse? @relation("ToWarehouse", fields: [toWarehouseId], references: [id], onDelete: SetNull)

  @@map("stock_movements")
}

model OwnerApplication {
  id                  Int       @id @default(autoincrement())
  userId              Int       @map("user_id")
  businessId          Int?      @map("business_id")
  businessName        String?   @map("business_name")
  businessDescription String?   @map("business_description")
  status              String    @default("pending")
  createdAt           DateTime  @default(now()) @map("created_at")
  reviewedAt          DateTime? @map("reviewed_at")
  reviewedBy          Int?      @map("reviewed_by")

  user     User      @relation("Applicant", fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  reviewer User?     @relation("Reviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@map("owner_applications")
}
